# ============================================================================
# Database
# ============================================================================
DATABASE_URL=postgres://gitcolony:gitcolony@localhost:5432/gitcolony

# ============================================================================
# Redis (BullMQ + SSE pub/sub)
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# Encryption — used to protect user PATs at rest.
# Generate with: openssl rand -base64 32
# Must be stable across restarts or existing PATs become unreadable.
# ============================================================================
ENCRYPTION_KEY=replace-me-with-32-bytes-base64

# ============================================================================
# GitHub OAuth (consumed by the OpenAuth issuer in apps/auth)
# Register an OAuth app at https://github.com/settings/developers
#   Homepage URL:         http://localhost:5173
#   Authorization callback: http://localhost:3001/github/callback
# ============================================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Port for the OpenAuth issuer (exposed as PUBLIC_AUTH_URL below)
AUTH_PORT=3001

# ============================================================================
# Public URLs (used in redirects, share links, OG previews)
# ============================================================================
PUBLIC_WEB_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3000
PUBLIC_AUTH_URL=http://localhost:3001

# ============================================================================
# Ingestion limits
# ============================================================================
INITIAL_COMMIT_LIMIT=1000
